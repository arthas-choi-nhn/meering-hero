{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Meering Hero",
  "version": "0.1.0",
  "identifier": "com.nhn.meering-hero",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Meering Hero",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "minimumSystemVersion": "13.0"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZBMDdBM0ZCMkE2RjhCNDEKUldSQmkyOHErNk1IYWxQRVpEYjNrTW9BSldkemRhNGdSc0VzcFRUZ2FLSnhjbEp5SE9GM1lTdkgK",
      "endpoints": [
        "https://github.com/arthas-choi-nhn/meering-hero/releases/latest/download/latest.json"
      ]
    }
  }
}
